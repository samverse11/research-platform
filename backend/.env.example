# =============================================================================
# API KEYS (Get your keys from the links below)
# =============================================================================

# Springer Nature API Key
# Get free key at:  https://dev.springernature.com/
SPRINGER_API_KEY=

# IEEE Xplore API Key  
# Get free key at: https://developer.ieee.org/
IEEE_API_KEY=

# SerpAPI (for Google Scholar - optional)
# Get key at: https://serpapi.com/
SERPAPI_KEY=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment (development, production)
DEBUG=True

# Device for ML models (cpu, cuda, mps)
DEVICE=cpu

# Embedding model
EMBEDDING_MODEL=intfloat/e5-base-v2

# =============================================================================
# SEARCH CONFIGURATION
# =============================================================================

# Maximum papers to fetch per source
MAX_PAPERS_PER_SOURCE=50

# Maximum total papers
MAX_PAPERS_LIMIT=1000

# Default number of results to return
DEFAULT_TOP_K=10

# Minimum similarity score (0.0 to 1.0)
MIN_SIMILARITY_SCORE=0.0

# =============================================================================
# VECTOR DATABASE (Optional)
# =============================================================================

# Use FAISS vector database
USE_VECTOR_DB=False

# Path to FAISS index
FAISS_INDEX_PATH=data/faiss_index